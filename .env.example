# Mochi env. Bun auto-loads this when you `cp .env.example .env`.
# Claude itself uses your Claude Code keychain OAuth — nothing extra.

# --- Required for full functionality ---

# Used by:
#   - Printable builds (gpt-image-2)
#   - English manifest titles for printables (gpt-4o-mini)
#   - The retitle-en script
# Without it, printables fail at the OpenAI call. Apps still work.
OPENAI_API_KEY=

# Used by the voice flow (STT + TTS proxied through /api/voice/*).
# Without it, the mic records but transcription fails, and Mochi's
# voice responses ("Hold on, Mochi is making it!") are silent.
ELEVENLABS_API_KEY=

# --- Optional, all have defaults baked in ---

# Claude model + reasoning effort for app builds, organize, and suggest.
# `sonnet` is the default — ~40% cheaper than opus and noticeably faster.
# `low` effort keeps sonnet from drifting into multi-minute thinking on
# short prompts. Bump to medium/high if you want it to think harder.
# MOCHI_CLAUDE_MODEL=sonnet
# MOCHI_CLAUDE_EFFORT=low

# ElevenLabs voice + model. Defaults are Rachel (multilingual, warm)
# on eleven_turbo_v2_5 (fast multilingual). Browse voices at:
# https://elevenlabs.io/voice-library
# MOCHI_TTS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# MOCHI_TTS_MODEL=eleven_turbo_v2_5
# MOCHI_STT_MODEL=scribe_v1
